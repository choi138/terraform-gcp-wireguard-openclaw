# Ops API listener
OPS_API_ADDR=:8080

# Required for protected endpoints
OPS_API_ADMIN_TOKEN=change-me-to-a-strong-random-token
# Use a distinct producer-only token for ingest writes.
OPS_API_INGEST_TOKEN=change-me-to-a-separate-ingest-token

# Optional OIDC operator auth
# OPS_API_OIDC_ISSUER=https://issuer.example.com
# OPS_API_OIDC_AUDIENCE=ops-api
# OPS_API_OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# OPS_API_OIDC_ROLES_CLAIM=roles
# OPS_API_OIDC_SUBJECT_CLAIM=sub
# OPS_API_OIDC_CLOCK_SKEW_SEC=60
# OPS_API_ADMIN_TOKEN_COMPATIBILITY=false

# Optional break-glass fallback (requires OIDC)
# OPS_API_BREAK_GLASS_ENABLED=false
# OPS_API_BREAK_GLASS_TOKEN=
# OPS_API_BREAK_GLASS_ROLE=admin
# OPS_API_BREAK_GLASS_EXPIRES_AT=2026-03-12T12:00:00Z
# OPS_API_BREAK_GLASS_ALLOWED_PATHS=/v1/security,/metrics
# OPS_API_BREAK_GLASS_REASON=
# OPS_API_BREAK_GLASS_APPROVER=

# Optional DB configuration
# Set true only for local smoke tests without a real database.
OPS_API_ALLOW_MEMORY_FALLBACK=true
OPS_API_DB_DRIVER=postgres
OPS_API_DB_DSN=

# HTTP server timeouts (seconds)
OPS_API_READ_TIMEOUT_SEC=10
OPS_API_WRITE_TIMEOUT_SEC=10

# Request body limits
OPS_API_INGEST_MAX_BODY_BYTES=1048576
OPS_API_SECURITY_MAX_BODY_BYTES=1048576

# Ingest retry worker
OPS_API_INGEST_RETRY_BASE_DELAY_MS=1000
OPS_API_INGEST_RETRY_MAX_DELAY_MS=30000
OPS_API_INGEST_RETRY_MAX_ATTEMPTS=5
OPS_API_INGEST_RETRY_WORKER_INTERVAL_MS=1000
OPS_API_INGEST_RETRY_BATCH_SIZE=20

# Request tracing
OPS_API_TRACE_EXPORTER=stdout
OPS_API_TRACE_SAMPLE_RATE=0.1
OPS_API_TRACE_SERVICE_NAME=ops-api

# Retention worker
OPS_API_RETENTION_ENABLED=false
OPS_API_RETENTION_DRY_RUN=true
OPS_API_RETENTION_INTERVAL_SEC=3600
OPS_API_RETENTION_MAX_ROWS_PER_RUN=500
OPS_API_RETENTION_MIN_WINDOW_HOURS=24
OPS_API_RETENTION_RAW_MESSAGE_HOURS=168
OPS_API_RETENTION_AUDIT_EVENT_HOURS=720
OPS_API_RETENTION_INFRA_SNAPSHOT_HOURS=720
OPS_API_RETENTION_INGEST_EVENT_HOURS=336
